---
import "../styles/global.css";
import FreeShippingBanner from "../components/sections/FreeShippingBanner.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Óleo de Avestruz Amazon Struthio — Suplemento 100% Natural com Ômegas 3, 6, 7 e 9 da Amazônia. 60 cápsulas de 760 mg com Vitaminas A, D3, K2 e Alquilgliceróis.",
  ogImage = "/oleo-avestruz-produto.png"
} = Astro.props;

const siteUrl = (Astro.site?.toString().replace(/\/$/, "") ?? "https://www.biototalnatural.com.br");
const canonicalUrl = Astro.url.href;
const resolvedOgImage =
  ogImage.startsWith("http://") || ogImage.startsWith("https://")
    ? ogImage
    : `${siteUrl}${ogImage}`;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Biototal Natural",
  "legalName": "BIO TOTAL - LTDA",
  "url": siteUrl,
  "logo": `${siteUrl}/favicon.png`,
  "taxID": "63.781.978/0001-58",
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": "+55-69-99237-8287",
      "contactType": "customer service",
      "availableLanguage": "Portuguese"
    },
    {
      "@type": "ContactPoint",
      "email": "sac@biototalnatural.com.br",
      "contactType": "customer service"
    }
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "R. Therezinha Navarro da Silva, 298",
    "addressLocality": "Hortolândia",
    "addressRegion": "SP",
    "postalCode": "13186-241",
    "addressCountry": "BR"
  }
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Óleo de Avestruz Amazon Struthio",
  "description": "Suplemento alimentar de alta biodisponibilidade com 4 Ômegas (3, 6, 7 e 9), Alquilgliceróis, Vitaminas A, B1, B5, B9, D3 e K2. 60 cápsulas de 760 mg. EPA + DHA de alto teor de pureza. Livre de metais pesados, sem retrogosto.",
  "image": `${siteUrl}/oleo-avestruz-produto.png`,
  "sku": "B0FR72DNTK",
  "mpn": "Omegas-3-6-7-9",
  "gtin13": "7898994625254",
  "brand": {
    "@type": "Brand",
    "name": "Amazon Struthio"
  },
  "category": "Saúde > Vitaminas e Suplementos > Ômega",
  "nutrition": {
    "@type": "NutritionInformation",
    "servingSize": "6,8 g (9 cápsulas)",
    "calories": "53 kcal",
    "proteinContent": "1,1 g",
    "fatContent": "5,4 g",
    "saturatedFatContent": "1,8 g",
    "unsaturatedFatContent": "3,7 g",
    "carbohydrateContent": "0 g",
    "sugarContent": "0 g",
    "sodiumContent": "0 mg"
  },
  "offers": [
    {
      "@type": "Offer",
      "name": "1 Frasco (30 dias)",
      "price": "80.20",
      "priceCurrency": "BRL",
      "availability": "https://schema.org/InStock",
      "url": "https://seguro.biototalnatural.com.br/r/2R1EV4DFWI",
      "seller": {
        "@type": "Organization",
        "name": "Biototal Natural"
      }
    },
    {
      "@type": "Offer",
      "name": "3 Frascos (90 dias)",
      "price": "216.53",
      "priceCurrency": "BRL",
      "availability": "https://schema.org/InStock",
      "url": "https://seguro.biototalnatural.com.br/r/FJNI20KIFF",
      "seller": {
        "@type": "Organization",
        "name": "Biototal Natural"
      }
    },
    {
      "@type": "Offer",
      "name": "5 Frascos (150 dias)",
      "price": "340.84",
      "priceCurrency": "BRL",
      "availability": "https://schema.org/InStock",
      "url": "https://seguro.biototalnatural.com.br/r/2OTG1X8MZ1",
      "seller": {
        "@type": "Organization",
        "name": "Biototal Natural"
      }
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "312",
    "bestRating": "5"
  }
};
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph Meta Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- JSON-LD: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

    <!-- JSON-LD: Product -->
    <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-W45MRJJF');</script>
    <!-- End Google Tag Manager -->

<!-- Meta Pixel Code -->
<script>
!function(f,b,e,v,n,t,s)
{if(f.fbq)return;n=f.fbq=function(){n.callMethod?
n.callMethod.apply(n,arguments):n.queue.push(arguments)};
if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
n.queue=[];t=b.createElement(e);t.async=!0;
t.src=v;s=b.getElementsByTagName(e)[0];
s.parentNode.insertBefore(t,s)}(window, document,'script',
'https://connect.facebook.net/en_US/fbevents.js');
fbq('init', '3227418370763990');
fbq('track', 'PageView');
</script>
<noscript><img height="1" width="1" style="display:none"
src="https://www.facebook.com/tr?id=3227418370763990&ev=PageView&noscript=1"
/></noscript>
<!-- End Meta Pixel Code -->
  </head>
  <body class="font-sans antialiased text-gray-900 bg-white">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W45MRJJF"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <FreeShippingBanner />
    <slot />

    <!-- WhatsApp Floating Button -->
    <a
      href="https://wa.me/5569992378287"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Fale conosco no WhatsApp"
      class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-lg hover:shadow-xl hover:scale-110 transition-all duration-300"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-7 h-7">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </body>
</html>
