---

<section id="video-testimonials" class="relative py-20 md:py-24 overflow-hidden">
  <!-- Background igual Benefits -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-br from-[#002E2A] via-[#004D40] to-[#00695C]"></div>
    <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-[#00897B]/20 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-[-15%] right-[-10%] w-[600px] h-[600px] bg-[#1B5E20]/15 rounded-full blur-[160px]"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-14">
      <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold tracking-wider text-[#CFFAE5] uppercase bg-white/10 border border-white/15 rounded-full">
        Depoimentos Reais
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Veja os <span class="text-[#FDC800]">Depoimentos</span> de Quem Usa e Aprova
      </h2>
      <p class="text-lg text-white/60">
        Histórias reais de clientes que transformaram sua saúde com o Óleo de Avestruz Amazon Struthio.
      </p>
    </div>

    <!-- Carousel -->
    <div class="relative max-w-5xl mx-auto">
      <!-- Arrows -->
      <button
        id="vt-prev"
        aria-label="Anterior"
        class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2 sm:-translate-x-4 z-20 w-10 h-10 md:w-12 md:h-12 bg-white/10 border border-white/20 backdrop-blur-sm rounded-full shadow-lg flex items-center justify-center text-white hover:bg-[#FDC800] hover:text-[#002E2A] transition-all duration-300"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        id="vt-next"
        aria-label="Próximo"
        class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2 sm:translate-x-4 z-20 w-10 h-10 md:w-12 md:h-12 bg-white/10 border border-white/20 backdrop-blur-sm rounded-full shadow-lg flex items-center justify-center text-white hover:bg-[#FDC800] hover:text-[#002E2A] transition-all duration-300"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Track -->
      <div class="overflow-hidden mx-8 sm:mx-12 md:mx-14">
        <div id="vt-track" class="flex gap-6 transition-transform duration-500 ease-in-out">
          {videos.map((video) => (
            <div class="vt-card flex-shrink-0 w-full md:w-[calc(50%-12px)]">
              <div class="group relative rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 border border-white/10 bg-white/5 backdrop-blur-sm">
                <!-- Thumbnail -->
                <div class="relative aspect-video cursor-pointer vt-thumb" data-video-id={video.id}>
                  <img
                    src={video.thumbnail}
                    alt={video.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-black/30 group-hover:bg-black/10 transition-colors duration-300"></div>
                  <!-- Play button -->
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-14 h-14 md:w-16 md:h-16 bg-[#FDC800] rounded-full flex items-center justify-center shadow-xl group-hover:scale-110 transition-transform duration-300">
                      <svg class="w-6 h-6 md:w-7 md:h-7 text-[#002E2A] ml-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z" />
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Dots -->
      <div id="vt-dots" class="flex justify-center gap-2 mt-8"></div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="#offers" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold bg-[#FDC800] hover:bg-[#e6b600] text-[#006252] rounded-full shadow-lg shadow-[#FDC800]/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
        Quero Minha Saúde de Volta
      </a>
    </div>
  </div>
</section>

<!-- YouTube Modal -->
<div id="vt-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4">
  <div class="relative w-full max-w-3xl aspect-video">
    <button id="vt-modal-close" class="absolute -top-10 right-0 text-white hover:text-[#FDC800] transition-colors">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <iframe
      id="vt-iframe"
      class="w-full h-full rounded-2xl shadow-2xl"
      src=""
      title="Video"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>
</div>

<script>
  const track = document.getElementById('vt-track') as HTMLElement;
  const prevBtn = document.getElementById('vt-prev') as HTMLElement;
  const nextBtn = document.getElementById('vt-next') as HTMLElement;
  const dotsContainer = document.getElementById('vt-dots') as HTMLElement;

  let currentIndex = 0;
  let autoplayInterval: ReturnType<typeof setInterval> | null = null;

  function getVisibleCards(): number {
    return window.innerWidth >= 768 ? 2 : 1;
  }

  function getTotalPages(): number {
    const cards = track.querySelectorAll('.vt-card');
    return Math.max(1, cards.length - getVisibleCards() + 1);
  }

  function updateCarousel(): void {
    const cards = track.querySelectorAll('.vt-card');
    if (cards.length === 0) return;
    const card = cards[0] as HTMLElement;
    const gap = 24;
    const cardWidth = card.offsetWidth + gap;
    track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;
    updateDots();
  }

  function createDots(): void {
    dotsContainer.innerHTML = '';
    const total = getTotalPages();
    for (let i = 0; i < total; i++) {
      const dot = document.createElement('button');
      dot.className = `h-2.5 rounded-full transition-all duration-300 ${i === currentIndex ? 'bg-[#FDC800] w-8' : 'bg-white/30 hover:bg-white/50 w-2.5'}`;
      dot.addEventListener('click', () => {
        currentIndex = i;
        updateCarousel();
        resetAutoplay();
      });
      dotsContainer.appendChild(dot);
    }
  }

  function updateDots(): void {
    const dots = dotsContainer.querySelectorAll('button');
    dots.forEach((dot, i) => {
      dot.className = `h-2.5 rounded-full transition-all duration-300 ${i === currentIndex ? 'bg-[#FDC800] w-8' : 'bg-white/30 hover:bg-white/50 w-2.5'}`;
    });
  }

  function goNext(): void {
    const total = getTotalPages();
    currentIndex = (currentIndex + 1) % total;
    updateCarousel();
  }

  function goPrev(): void {
    const total = getTotalPages();
    currentIndex = (currentIndex - 1 + total) % total;
    updateCarousel();
  }

  function startAutoplay(): void {
    if (autoplayInterval) clearInterval(autoplayInterval);
    autoplayInterval = setInterval(goNext, 4000);
  }

  function resetAutoplay(): void {
    startAutoplay();
  }

  prevBtn.addEventListener('click', () => { goPrev(); resetAutoplay(); });
  nextBtn.addEventListener('click', () => { goNext(); resetAutoplay(); });

  // Pause on hover
  track.addEventListener('mouseenter', () => {
    if (autoplayInterval) clearInterval(autoplayInterval);
  });
  track.addEventListener('mouseleave', () => { startAutoplay(); });

  window.addEventListener('resize', () => {
    currentIndex = 0;
    createDots();
    updateCarousel();
  });

  createDots();
  updateCarousel();
  startAutoplay();

  // Modal
  const modal = document.getElementById('vt-modal') as HTMLElement;
  const iframe = document.getElementById('vt-iframe') as HTMLIFrameElement;
  const closeBtn = document.getElementById('vt-modal-close') as HTMLElement;
  const thumbs = document.querySelectorAll('.vt-thumb');

  thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const videoId = (thumb as HTMLElement).dataset.videoId;
      iframe.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      if (autoplayInterval) clearInterval(autoplayInterval);
    });
  });

  function closeModal(): void {
    iframe.src = '';
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
    startAutoplay();
  }

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
</script>
