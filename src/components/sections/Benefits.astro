---
import Section from "../ui/Section.astro";
import Card from "../ui/Card.astro";

import imgInflamacao from "../../assets/images/benefits/inflamacao-cronica.png";
import imgCoracao from "../../assets/images/benefits/saude-do-coracao.png";
import imgOssos from "../../assets/images/benefits/saude-dos-ossos.png";
import imgJoelhos from "../../assets/images/benefits/dores-nos-joelhos.png";
import imgOmbros from "../../assets/images/benefits/dores-nos-ombros.png";
import imgReumatismo from "../../assets/images/benefits/reumatismo.png";

const benefits = [
  {
    image: imgInflamacao,
    title: "Inflamação Crônica",
    description: "Ômega 3 age direto na causa das inflamações, reduzindo dores e desconfortos que afetam sua qualidade de vida.",
  },
  {
    image: imgCoracao,
    title: "Saúde do Coração",
    description: "Ômega 3 e 9 regulam a pressão arterial e protegem contra coágulos, prevenindo AVC e infartos.",
  },
  {
    image: imgOssos,
    title: "Saúde dos Ossos",
    description: "Vitamina D3 fortalece a estrutura óssea e melhora a absorção de cálcio, prevenindo osteoporose.",
  },
  {
    image: imgJoelhos,
    title: "Dores nos Joelhos",
    description: "Ômega 3 e Alquilgliceróis combatem a inflamação articular, devolvendo mobilidade e conforto ao caminhar.",
  },
  {
    image: imgOmbros,
    title: "Dores nos Ombros",
    description: "Ômegas 3 e 6 atuam na regeneração dos tecidos e reduzem a rigidez, aliviando dores e tensões nos ombros.",
  },
  {
    image: imgReumatismo,
    title: "Reumatismo",
    description: "Alquilgliceróis e Ômega 3 modulam o sistema imunológico e reduzem inflamações reumáticas crônicas.",
  },
];
---

<section id="benefits" class="relative py-24 overflow-hidden">
  <!-- Same bg as Hero -->
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-br from-[#002E2A] via-[#004D40] to-[#00695C]"></div>
    <div class="absolute top-[-10%] left-[-5%] w-[500px] h-[500px] bg-[#00897B]/20 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-[-15%] right-[-10%] w-[600px] h-[600px] bg-[#1B5E20]/15 rounded-full blur-[160px]"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <div class="inline-block px-3 py-1 mb-4 text-xs font-semibold tracking-wider text-[#CFFAE5] uppercase bg-white/10 border border-white/15 rounded-full">
        Por que escolher
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
        Benefícios dos <span class="text-[#FDC800]">Ômegas da Amazônia</span>
      </h2>
      <p class="text-lg text-white/60">
        Descubra como um suplemento 100% natural pode transformar sua saúde de dentro para fora com tecnologia avançada.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {benefits.map((benefit) => (
        <div class="relative bg-gradient-to-br from-[#002E2A] via-[#004D40] to-[#00695C] border border-[#FDC800]/30 rounded-2xl p-6 hover:-translate-y-1 hover:border-[#FDC800]/50 transition-all duration-300 text-center shadow-lg overflow-hidden">
          <div class="absolute inset-0 opacity-[0.08] rounded-2xl" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size: 150px;"></div>
          <div class="relative z-10">
            <div class="flex justify-center mb-5">
              <img
                src={benefit.image.src}
                width={benefit.image.width}
                height={benefit.image.height}
                alt={benefit.title}
                class="w-20 h-20 object-contain"
                loading="lazy"
              />
            </div>
            <h3 class="text-xl font-bold text-[#FBC630] mb-3">{benefit.title}</h3>
            <p class="text-white/70 leading-relaxed">
              {benefit.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="#offers" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold bg-[#FDC800] hover:bg-[#e6b600] text-[#006252] rounded-full shadow-lg shadow-[#FDC800]/30 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
        Quero Minha Saúde de Volta
      </a>
    </div>
  </div>
</section>
